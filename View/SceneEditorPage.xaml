<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetPOO.View.SceneEditorPage"
             BackgroundColor="#F3F3F3">

    <ContentPage.Resources>
        <ResourceDictionary>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="BackgroundColor" Value="#3B82F6" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="DarkButtonStyle" TargetType="Button">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="BackgroundColor" Value="#2D2D32" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="TextColor" Value="#2D2D32" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="SectionFrameStyle" TargetType="Frame">
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BorderColor" Value="#DDDDDD" />
                <Setter Property="BackgroundColor" Value="White" />
            </Style>

            <Style x:Key="FieldLabelStyle" TargetType="Label">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="TextColor" Value="#111111" />
            </Style>

            <Style x:Key="HintLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="#7A7A7A" />
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="20"
              RowDefinitions="Auto,*">

            <!-- Header -->
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="14"
                                 Margin="0,0,0,24">

                <Button Text="← Retour au scénario"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalOptions="Start" />

                <Label Text="Éditeur de Scène"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#111111"
                       HorizontalOptions="Center" />

            </VerticalStackLayout>

            <!-- Contenu -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="22">

                <!-- Bloc principal -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">

                        <VerticalStackLayout Padding="20"
                                             Spacing="22">

                            <!-- Titre -->
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Titre de la scène"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Entry Text="{Binding SceneTitle}"
                                       Placeholder="Titre de la scène"
                                       BackgroundColor="#F5F5F7"
                                       TextColor="#111111"
                                       HeightRequest="50" />
                            </VerticalStackLayout>

                            <!-- Texte -->
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Texte narratif"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Editor Text="{Binding SceneText}"
                                        Placeholder="Décrivez ce qui se passe dans cette scène..."
                                        BackgroundColor="#F5F5F7"
                                        TextColor="#111111"
                                        AutoSize="TextChanges"
                                        MinimumHeightRequest="150" />
                            </VerticalStackLayout>

                            <!-- Type + image -->
                            <Grid ColumnDefinitions="1.1*,0.9*"
                                  ColumnSpacing="20">

                                <!-- Type -->
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="10">
                                    <Label Text="Type de scène"
                                           Style="{StaticResource FieldLabelStyle}" />

                                    <Picker ItemsSource="{Binding SceneTypes}"
                                            SelectedItem="{Binding SelectedSceneType}"
                                            BackgroundColor="#F5F5F7"
                                            TextColor="#111111"
                                            Title="Choisir un type" />
                                </VerticalStackLayout>

                                <!-- Image -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="10">
                                    <Label Text="Image de la scène (optionnelle)"
                                           Style="{StaticResource FieldLabelStyle}" />

                                    <Button Text="Parcourir"
                                            Command="{Binding BrowseImageCommand}"
                                            Style="{StaticResource DarkButtonStyle}"
                                            HorizontalOptions="Start" />

                                    <Label Text="{Binding SelectedImageFileName}"
                                           Style="{StaticResource HintLabelStyle}" />

                                    <!-- Zone d’aperçu -->
                                    <Frame Padding="8"
                                           CornerRadius="12"
                                           HasShadow="False"
                                           BorderColor="#DDDDDD"
                                           BackgroundColor="#FAFAFA"
                                           HeightRequest="170">

                                        <Grid>
                                            <Image Source="{Binding SceneImagePreview}"
                                                   Aspect="AspectFit"
                                                   IsVisible="{Binding HasSceneImagePreview}" />

                                            <Label Text="Aucune image sélectionnée"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   TextColor="#9A9A9A"
                                                   FontSize="13"
                                                   IsVisible="{Binding HasNoSceneImagePreview}" />
                                        </Grid>
                                    </Frame>

                                </VerticalStackLayout>

                            </Grid>

                            <!-- Bloc Ennemi : Combat -->
                            <VerticalStackLayout Spacing="10"
                                                 IsVisible="{Binding IsEnemySelectionVisible}">
                                <Label Text="Ennemi"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Picker ItemsSource="{Binding Enemies}"
                                        SelectedItem="{Binding SelectedEnemy}"
                                        ItemDisplayBinding="{Binding Name}"
                                        BackgroundColor="#F5F5F7"
                                        TextColor="#111111"
                                        Title="Choisir un ennemi" />
                            </VerticalStackLayout>

                            <!-- Bloc Destinations combat -->
                            <Grid ColumnDefinitions="1*,1*"
                                  ColumnSpacing="20"
                                  IsVisible="{Binding IsCombatScene}">

                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="10">
                                    <Label Text="Scène en cas de victoire"
                                           Style="{StaticResource FieldLabelStyle}" />

                                    <Picker ItemsSource="{Binding AvailableScenesForCombatTargets}"
                                            SelectedItem="{Binding SelectedVictoryTargetScene}"
                                            ItemDisplayBinding="{Binding Title}"
                                            BackgroundColor="#F5F5F7"
                                            TextColor="#111111"
                                            Title="Choisir une scène" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="10">
                                    <Label Text="Scène en cas de défaite"
                                           Style="{StaticResource FieldLabelStyle}" />

                                    <Picker ItemsSource="{Binding AvailableScenesForCombatTargets}"
                                            SelectedItem="{Binding SelectedDefeatTargetScene}"
                                            ItemDisplayBinding="{Binding Title}"
                                            BackgroundColor="#F5F5F7"
                                            TextColor="#111111"
                                            Title="Choisir une scène" />
                                </VerticalStackLayout>

                            </Grid>

                            <VerticalStackLayout Spacing="10"
                                                 IsVisible="{Binding IsCombatScene}">
                                <Label Text="Scène en cas de fuite"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Picker ItemsSource="{Binding AvailableScenesForCombatTargets}"
                                        SelectedItem="{Binding SelectedFleeTargetScene}"
                                        ItemDisplayBinding="{Binding Title}"
                                        BackgroundColor="#F5F5F7"
                                        TextColor="#111111"
                                        Title="Choisir une scène" />
                            </VerticalStackLayout>

                            <!-- Bloc Boutique : Shop -->
                            <VerticalStackLayout Spacing="10"
                                                 IsVisible="{Binding IsShopSelectionVisible}">
                                <Label Text="Boutique"
                                       Style="{StaticResource FieldLabelStyle}" />

                                <Picker ItemsSource="{Binding Shops}"
                                        SelectedItem="{Binding SelectedShop}"
                                        ItemDisplayBinding="{Binding Name}"
                                        BackgroundColor="#F5F5F7"
                                        TextColor="#111111"
                                        Title="Choisir une boutique" />
                            </VerticalStackLayout>

                            <!-- Message End -->
                            <Label Text="Cette scène de fin ne contient pas de choix."
                                   TextColor="#7A7A7A"
                                   FontSize="14"
                                   IsVisible="{Binding IsEndScene}" />

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Bloc choix -->
                <Grid ColumnDefinitions="1*,8*,1*"
                      IsVisible="{Binding AreChoicesVisible}">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">

                        <VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto"
                                  Padding="20,16">
                                <Label Grid.Column="0"
                                       Text="Choix disponibles"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />

                                <Button Grid.Column="1"
                                        Text="+ Ajouter un choix"
                                        Command="{Binding AddChoiceCommand}"
                                        Style="{StaticResource DarkButtonStyle}" />
                            </Grid>

                            <BoxView HeightRequest="1"
                                     BackgroundColor="#E5E5E5" />

                            <CollectionView ItemsSource="{Binding Choices}"
                                            SelectionMode="None"
                                            Margin="0,10,0,10">

                                <CollectionView.EmptyView>
                                    <Label Text="Aucun choix"
                                           HorizontalOptions="Center"
                                           TextColor="#8A8A8A"
                                           Margin="0,20,0,20" />
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Frame Margin="20,10,20,10"
                                               Padding="16"
                                               CornerRadius="12"
                                               HasShadow="False"
                                               BorderColor="#E2E2E2"
                                               BackgroundColor="#F8F8FA">

                                            <Grid ColumnDefinitions="*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="12"
                                                  RowSpacing="14">

                                                <VerticalStackLayout Grid.Row="0"
                                                                     Grid.Column="0"
                                                                     Spacing="8">
                                                    <Label Text="Texte du choix"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#6B7280" />

                                                    <Entry Text="{Binding Label}"
                                                           Placeholder="Nouveau choix"
                                                           BackgroundColor="White"
                                                           TextColor="#111111" />
                                                </VerticalStackLayout>

                                                <Button Grid.Row="0"
                                                        Grid.Column="1"
                                                        Text="🗑"
                                                        BackgroundColor="Transparent"
                                                        TextColor="#F04438"
                                                        FontSize="18"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteChoiceCommand}"
                                                        CommandParameter="{Binding}"
                                                        VerticalOptions="Center" />

                                                <VerticalStackLayout Grid.Row="1"
                                                                     Grid.Column="0"
                                                                     Grid.ColumnSpan="2"
                                                                     Spacing="8">
                                                    <Label Text="Scène de destination"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#6B7280" />

                                                    <Picker ItemsSource="{Binding AvailableTargetScenes}"
                                                            SelectedItem="{Binding SelectedTargetScene}"
                                                            ItemDisplayBinding="{Binding Title}"
                                                            BackgroundColor="White"
                                                            TextColor="#111111"
                                                            Title="Choisir une scène" />
                                                </VerticalStackLayout>

                                            </Grid>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>

                            </CollectionView>

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Sauvegarde -->
                <Grid ColumnDefinitions="1*,8*,1*"
                      Margin="0,10,0,30">

                    <Button Grid.Column="1"
                            Text="Sauvegarder la scène"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="52" />
                </Grid>

            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>