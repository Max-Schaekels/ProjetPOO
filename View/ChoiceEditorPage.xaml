<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ProjetPOO.View.ChoiceEditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#f3f3f3">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Button
                Text="← Retour à la scène"
                Command="{Binding BackCommand}"
                HorizontalOptions="Start"
                BackgroundColor="Transparent"
                TextColor="#333333" />

            <Label
                Text="{Binding PageTitle}"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Border
                BackgroundColor="White"
                Stroke="#dddddd"
                StrokeThickness="1"
                Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Texte du choix"
                            FontSize="16"
                            FontAttributes="Bold" />

                        <Entry
                            Text="{Binding ChoiceLabel}"
                            Placeholder="Exemple : Entrer dans la forêt"
                            BackgroundColor="#f5f5f7" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Scène de destination"
                            FontSize="16"
                            FontAttributes="Bold" />

                        <Picker
                            Title="Choisir une scène"
                            ItemsSource="{Binding AvailableTargetScenes}"
                            SelectedItem="{Binding SelectedTargetScene}"
                            ItemDisplayBinding="{Binding Title}"
                            BackgroundColor="#f5f5f7" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="White"
                Stroke="#dddddd"
                StrokeThickness="1"
                Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <Grid Padding="20" ColumnDefinitions="*,Auto">
                        <Label
                            Text="Conditions"
                            FontSize="16"
                            FontAttributes="Bold"
                            VerticalOptions="Center" />

                        <Button
                            Grid.Column="1"
                            Text="+ Nouvelle condition"
                            Command="{Binding NewConditionCommand}"
                            BackgroundColor="#25252d"
                            TextColor="White"
                            CornerRadius="8" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#eeeeee" />

                    <Label
                        Text="Aucune condition"
                        Padding="20"
                        TextColor="#888888" />

                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="White"
                Stroke="#dddddd"
                StrokeThickness="1"
                Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <Grid Padding="20" ColumnDefinitions="*,Auto">
                        <Label
                            Text="Effets"
                            FontSize="16"
                            FontAttributes="Bold"
                            VerticalOptions="Center" />

                        <Button
                            Grid.Column="1"
                            Text="+ Nouvel effet"
                            Command="{Binding NewEffectCommand}"
                            BackgroundColor="#25252d"
                            TextColor="White"
                            CornerRadius="8" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#eeeeee" />

                    <Label
                        Text="Aucun effet"
                        Padding="20"
                        TextColor="#888888" />

                </VerticalStackLayout>
            </Border>

            <Button
                Text="Sauvegarder le choix"
                Command="{Binding SaveCommand}"
                HeightRequest="55"
                BackgroundColor="#3b82f6"
                TextColor="White"
                CornerRadius="8"
                FontAttributes="Bold" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>