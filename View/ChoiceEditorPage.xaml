<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ProjetPOO.View.ChoiceEditorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#f3f3f3">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Button
                Text="← Retour à la scène"
                Command="{Binding BackCommand}"
                HorizontalOptions="Start"
                BackgroundColor="Transparent"
                TextColor="#333333" />

            <Label
                Text="{Binding PageTitle}"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Border
                BackgroundColor="White"
                Stroke="#dddddd"
                StrokeThickness="1"
                Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Texte du choix"
                            FontSize="16"
                            FontAttributes="Bold" />

                        <Entry
                            Text="{Binding ChoiceLabel}"
                            Placeholder="Exemple : Entrer dans la forêt"
                            BackgroundColor="#f5f5f7" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Scène de destination"
                            FontSize="16"
                            FontAttributes="Bold" />

                        <Picker
                            Title="Choisir une scène"
                            ItemsSource="{Binding AvailableTargetScenes}"
                            SelectedItem="{Binding SelectedTargetScene}"
                            ItemDisplayBinding="{Binding Title}"
                            BackgroundColor="#f5f5f7" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="White"
                Stroke="#dddddd"
                StrokeThickness="1"
                Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <Grid Padding="20" ColumnDefinitions="*,Auto">
                        <Label
                            Text="Conditions"
                            FontSize="16"
                            FontAttributes="Bold"
                            VerticalOptions="Center" />

                        <Button
                            Grid.Column="1"
                            Text="+ Nouvelle condition"
                            Command="{Binding NewConditionCommand}"
                            BackgroundColor="#25252d"
                            TextColor="White"
                            CornerRadius="8" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#eeeeee" />

                    <CollectionView ItemsSource="{Binding Conditions}"
                SelectionMode="None"
                Margin="0,10,0,10">

                        <CollectionView.EmptyView>
                            <Label Text="Aucune condition"
               HorizontalOptions="Center"
               TextColor="#888888"
               Margin="0,20,0,20" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="20,10,20,10"
                   Padding="14"
                   CornerRadius="12"
                   HasShadow="False"
                   BorderColor="#E5E5E5"
                   BackgroundColor="#FAFAFA">

                                    <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="16"
                      RowSpacing="4">

                                        <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding Type, StringFormat='Type : {0}'}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#111111" />

                                        <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding MinValue, StringFormat='Valeur : {0}'}"
                           FontSize="13"
                           TextColor="#6B7280" />

                                        <HorizontalStackLayout Grid.Row="0"
                                           Grid.Column="1"
                                           Grid.RowSpan="2"
                                           Spacing="8"
                                           VerticalOptions="Center">

                                            <Button Text="✎"
                                BackgroundColor="#2D2D32"
                                TextColor="White"
                                CornerRadius="8"
                                WidthRequest="38"
                                HeightRequest="38"
                                Padding="0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditConditionCommand}"
                                CommandParameter="{Binding}" />

                                            <Button Text="🗑"
                                BackgroundColor="#F04438"
                                TextColor="White"
                                CornerRadius="8"
                                WidthRequest="38"
                                HeightRequest="38"
                                Padding="0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteConditionCommand}"
                                CommandParameter="{Binding}" />

                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="White"
                Stroke="#dddddd"
                StrokeThickness="1"
                Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <Grid Padding="20" ColumnDefinitions="*,Auto">
                        <Label
                            Text="Effets"
                            FontSize="16"
                            FontAttributes="Bold"
                            VerticalOptions="Center" />

                        <Button
                            Grid.Column="1"
                            Text="+ Nouvel effet"
                            Command="{Binding NewEffectCommand}"
                            BackgroundColor="#25252d"
                            TextColor="White"
                            CornerRadius="8" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#eeeeee" />

                    <CollectionView ItemsSource="{Binding Effects}"
                SelectionMode="None"
                Margin="0,10,0,10">

                        <CollectionView.EmptyView>
                            <Label Text="Aucun effet"
               HorizontalOptions="Center"
               TextColor="#888888"
               Margin="0,20,0,20" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="20,10,20,10"
                   Padding="14"
                   CornerRadius="12"
                   HasShadow="False"
                   BorderColor="#E5E5E5"
                   BackgroundColor="#FAFAFA">

                                    <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="16"
                      RowSpacing="4">

                                        <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding Type, StringFormat='Type : {0}'}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#111111" />

                                        <Label Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding Amount, StringFormat='Quantité : {0}', TargetNullValue='Quantité : -'}"
                           FontSize="13"
                           TextColor="#6B7280" />

                                        <Label Grid.Row="2"
                           Grid.Column="0"
                           Text="{Binding FlagKey, StringFormat='Repère : {0}', TargetNullValue='Repère : -'}"
                           FontSize="13"
                           TextColor="#6B7280" />

                                        <HorizontalStackLayout Grid.Row="0"
                                           Grid.Column="1"
                                           Grid.RowSpan="3"
                                           Spacing="8"
                                           VerticalOptions="Center">

                                            <Button Text="✎"
                                BackgroundColor="#2D2D32"
                                TextColor="White"
                                CornerRadius="8"
                                WidthRequest="38"
                                HeightRequest="38"
                                Padding="0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditEffectCommand}"
                                CommandParameter="{Binding}" />

                                            <Button Text="🗑"
                                BackgroundColor="#F04438"
                                TextColor="White"
                                CornerRadius="8"
                                WidthRequest="38"
                                HeightRequest="38"
                                Padding="0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteEffectCommand}"
                                CommandParameter="{Binding}" />

                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>

            <Button
                Text="Sauvegarder le choix"
                Command="{Binding SaveCommand}"
                HeightRequest="55"
                BackgroundColor="#3b82f6"
                TextColor="White"
                CornerRadius="8"
                FontAttributes="Bold" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>