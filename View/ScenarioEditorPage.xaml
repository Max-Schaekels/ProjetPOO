<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetPOO.View.ScenarioEditorPage"
             BackgroundColor="#F3F3F3">

    <ContentPage.Resources>
        <ResourceDictionary>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="BackgroundColor" Value="#3B82F6" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="TextColor" Value="#2D2D32" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="SectionFrameStyle" TargetType="Frame">
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BorderColor" Value="#DDDDDD" />
                <Setter Property="BackgroundColor" Value="White" />
            </Style>

            <Style x:Key="ElementFrameStyle" TargetType="Frame">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BorderColor" Value="#E5E5E5" />
                <Setter Property="BackgroundColor" Value="#FAFAFA" />
            </Style>

            <Style x:Key="SmallActionButtonStyle" TargetType="Button">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="WidthRequest" Value="38" />
                <Setter Property="HeightRequest" Value="38" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="0" />
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="20"
              RowDefinitions="Auto,Auto,*">

            <!-- Header -->
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="10"
                                 Margin="0,0,0,20">

                <Button Text="← Retour à la liste"
                        Command="{Binding BackCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#2D2D32"
                        Padding="0"
                        HorizontalOptions="Start" />

                <Label Text="Éditeur de Scénario"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#111111"
                       HorizontalOptions="Center" />

            </VerticalStackLayout>

            <!-- Formulaire principal -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="1*,8*,1*">

                <Frame Grid.Column="1"
                       Style="{StaticResource SectionFrameStyle}"
                       Margin="0,0,0,20">

                    <VerticalStackLayout Padding="20"
                                         Spacing="18">

                        <Label Text="Titre"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#111111" />

                        <Entry Text="{Binding ScenarioTitle}"
                               Placeholder="Titre du scénario"
                               BackgroundColor="#F5F5F7"
                               TextColor="#111111"
                               HeightRequest="50" />

                        <Label Text="Description"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#111111" />

                        <Editor Text="{Binding ScenarioDescription}"
                                Placeholder="Description du scénario"
                                BackgroundColor="#F5F5F7"
                                TextColor="#111111"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="120" />

                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Sections -->
            <VerticalStackLayout Grid.Row="2"
                                 Spacing="18">

                <!-- Scènes -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">

                        <VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  Padding="20,16">

                                <Label Grid.Column="0"
                                       Text="Scènes"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111111"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Text="{Binding ScenesCount, StringFormat='({0})'}"
                                       FontSize="14"
                                       TextColor="#7A7A7A"
                                       Margin="8,0,16,0"
                                       VerticalOptions="Center" />

                                <Button Grid.Column="2"
                                        Text="+ Nouveau"
                                        Command="{Binding AddSceneCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />

                            </Grid>

                            <BoxView HeightRequest="1"
                                     BackgroundColor="#E5E5E5" />

                            <Label Text="Aucune scène"
                                   HorizontalOptions="Center"
                                   TextColor="#8A8A8A"
                                   Margin="0,20,0,20"
                                   IsVisible="{Binding IsScenesEmpty}" />

                            <VerticalStackLayout Padding="20,12"
                                                 Spacing="10"
                                                 BindableLayout.ItemsSource="{Binding Scenes}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>

                                        <Frame Style="{StaticResource ElementFrameStyle}">

                                            <Grid ColumnDefinitions="*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="16"
                                                  RowSpacing="4">

                                                <Label Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{Binding Title}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       TextColor="#111111" />

                                                <Label Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="{Binding SceneType, StringFormat='Type : {0}'}"
                                                       FontSize="13"
                                                       TextColor="#6B7280" />

                                                <HorizontalStackLayout Grid.Row="0"
                                                                       Grid.Column="1"
                                                                       Grid.RowSpan="2"
                                                                       Spacing="8"
                                                                       VerticalOptions="Center">

                                                    <Button Text="✎"
                                                            BackgroundColor="#2D2D32"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditSceneCommand}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}" />

                                                    <Button Text="🗑"
                                                            BackgroundColor="#F04438"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteSceneCommand}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}" />

                                                </HorizontalStackLayout>

                                            </Grid>
                                        </Frame>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Ennemis -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">

                        <VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  Padding="20,16">

                                <Label Grid.Column="0"
                                       Text="Ennemis"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111111"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Text="{Binding EnemiesCount, StringFormat='({0})'}"
                                       FontSize="14"
                                       TextColor="#7A7A7A"
                                       Margin="8,0,16,0"
                                       VerticalOptions="Center" />

                                <Button Grid.Column="2"
                                        Text="+ Nouveau"
                                        Command="{Binding AddEnemyCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />

                            </Grid>

                            <BoxView HeightRequest="1"
                                     BackgroundColor="#E5E5E5" />

                            <Label Text="Aucun ennemi"
                                   HorizontalOptions="Center"
                                   TextColor="#8A8A8A"
                                   Margin="0,20,0,20"
                                   IsVisible="{Binding IsEnemiesEmpty}" />

                            <VerticalStackLayout Padding="20,12"
                                                 Spacing="10"
                                                 BindableLayout.ItemsSource="{Binding Enemies}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>

                                        <Frame Style="{StaticResource ElementFrameStyle}">

                                            <Grid ColumnDefinitions="*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="16"
                                                  RowSpacing="4">

                                                <Label Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{Binding EnemyName, TargetNullValue='Ennemi générique'}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       TextColor="#111111" />

                                                <Label Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="{Binding EnemyRaceId, StringFormat='Race ID : {0}'}"
                                                       FontSize="13"
                                                       TextColor="#6B7280" />

                                                <HorizontalStackLayout Grid.Row="0"
                                                                       Grid.Column="1"
                                                                       Grid.RowSpan="2"
                                                                       Spacing="8"
                                                                       VerticalOptions="Center">

                                                    <Button Text="✎"
                                                            BackgroundColor="#2D2D32"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditEnemyCommand}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}" />

                                                    <Button Text="🗑"
                                                            BackgroundColor="#F04438"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteEnemyCommand}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}" />

                                                </HorizontalStackLayout>

                                            </Grid>
                                        </Frame>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Boutiques -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">

                        <VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  Padding="20,16">

                                <Label Grid.Column="0"
                                       Text="Boutiques"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111111"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Text="{Binding ShopsCount, StringFormat='({0})'}"
                                       FontSize="14"
                                       TextColor="#7A7A7A"
                                       Margin="8,0,16,0"
                                       VerticalOptions="Center" />

                                <Button Grid.Column="2"
                                        Text="+ Nouveau"
                                        Command="{Binding AddShopCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />

                            </Grid>

                            <BoxView HeightRequest="1"
                                     BackgroundColor="#E5E5E5" />

                            <Label Text="Aucune boutique"
                                   HorizontalOptions="Center"
                                   TextColor="#8A8A8A"
                                   Margin="0,20,0,20"
                                   IsVisible="{Binding IsShopsEmpty}" />

                            <VerticalStackLayout Padding="20,12"
                                                 Spacing="10"
                                                 BindableLayout.ItemsSource="{Binding Shops}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>

                                        <Frame Style="{StaticResource ElementFrameStyle}">

                                            <Grid ColumnDefinitions="*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="16"
                                                  RowSpacing="4">

                                                <Label Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       TextColor="#111111" />

                                                <Label Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="{Binding PotionPrice, StringFormat='Potion : {0} pièces'}"
                                                       FontSize="13"
                                                       TextColor="#6B7280" />

                                                <HorizontalStackLayout Grid.Row="0"
                                                                       Grid.Column="1"
                                                                       Grid.RowSpan="2"
                                                                       Spacing="8"
                                                                       VerticalOptions="Center">

                                                    <Button Text="✎"
                                                            BackgroundColor="#2D2D32"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditShopCommand}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}" />

                                                    <Button Text="🗑"
                                                            BackgroundColor="#F04438"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteShopCommand}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}" />

                                                </HorizontalStackLayout>

                                            </Grid>
                                        </Frame>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Personnages -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">

                        <VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  Padding="20,16">

                                <Label Grid.Column="0"
                                       Text="Personnages"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111111"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Text="{Binding PlayerCharactersCount, StringFormat='({0})'}"
                                       FontSize="14"
                                       TextColor="#7A7A7A"
                                       Margin="8,0,16,0"
                                       VerticalOptions="Center" />

                                <Button Grid.Column="2"
                                        Text="+ Nouveau"
                                        Command="{Binding AddPlayerCharacterCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />

                            </Grid>

                            <BoxView HeightRequest="1"
                                     BackgroundColor="#E5E5E5" />

                            <Label Text="Aucun personnage"
                                   HorizontalOptions="Center"
                                   TextColor="#8A8A8A"
                                   Margin="0,20,0,20"
                                   IsVisible="{Binding IsPlayerCharactersEmpty}" />

                            <VerticalStackLayout Padding="20,12"
                                                 Spacing="10"
                                                 BindableLayout.ItemsSource="{Binding PlayerCharacters}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>

                                        <Frame Style="{StaticResource ElementFrameStyle}">

                                            <Grid ColumnDefinitions="*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="16"
                                                  RowSpacing="4">

                                                <Label Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       TextColor="#111111" />

                                                <Label Grid.Row="1"
                                                       Grid.Column="0"
                                                       Text="{Binding ClassName, StringFormat='Classe : {0}'}"
                                                       FontSize="13"
                                                       TextColor="#6B7280" />

                                                <HorizontalStackLayout Grid.Row="0"
                                                                       Grid.Column="1"
                                                                       Grid.RowSpan="2"
                                                                       Spacing="8"
                                                                       VerticalOptions="Center">

                                                    <Button Text="✎"
                                                            BackgroundColor="#2D2D32"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditPlayerCharacterCommand}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}" />

                                                    <Button Text="🗑"
                                                            BackgroundColor="#F04438"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeletePlayerCharacterCommand}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}" />

                                                </HorizontalStackLayout>

                                            </Grid>
                                        </Frame>

                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Sauvegarde -->
                <Grid ColumnDefinitions="1*,8*,1*"
                      Margin="0,20,0,30">

                    <Button Grid.Column="1"
                            Text="Sauvegarder le scénario"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="50" />

                </Grid>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>