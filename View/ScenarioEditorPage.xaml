<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProjetPOO.View.ScenarioEditorPage"
             BackgroundColor="#F3F3F3">

    <ContentPage.Resources>
        <ResourceDictionary>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="BackgroundColor" Value="#3B82F6" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="TextColor" Value="#2D2D32" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="SectionFrameStyle" TargetType="Frame">
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BorderColor" Value="#DDDDDD" />
                <Setter Property="BackgroundColor" Value="White" />
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="20"
              RowDefinitions="Auto,Auto,*">

            <!-- Header -->
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="10"
                                 Margin="0,0,0,20">

                <Button Text="← Retour à la liste"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalOptions="Start" />

                <Label Text="Éditeur de Scénario"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#111111" />

            </VerticalStackLayout>

            <!-- Formulaire principal -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="1*,8*,1*">

                <Frame Grid.Column="1"
                       Style="{StaticResource SectionFrameStyle}"
                       Margin="0,0,0,20">

                    <VerticalStackLayout Padding="20"
                                         Spacing="18">

                        <Label Text="Titre"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#111111" />

                        <Entry Text="{Binding ScenarioTitle}"
                               Placeholder="Titre du scénario"
                               BackgroundColor="#F5F5F7"
                               TextColor="#111111"
                               HeightRequest="50" />

                        <Label Text="Description"
                               FontAttributes="Bold"
                               FontSize="16"
                               TextColor="#111111" />

                        <Editor Text="{Binding ScenarioDescription}"
                                Placeholder="Description du scénario"
                                BackgroundColor="#F5F5F7"
                                TextColor="#111111"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="120" />

                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Sections -->
            <VerticalStackLayout Grid.Row="2"
                                 Spacing="18">

                <!-- Scènes -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">
                        <VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  Padding="20,16">
                                <Label Grid.Column="0"
                                       Text="Scènes"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Text="{Binding ScenesCount, StringFormat='({0})'}"
                                       FontSize="14"
                                       TextColor="#7A7A7A"
                                       Margin="8,0,16,0"
                                       VerticalOptions="Center" />

                                <Button Grid.Column="2"
                                        Text="+ Ajouter"
                                        Command="{Binding AddSceneCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                            </Grid>

                            <BoxView HeightRequest="1"
                                     BackgroundColor="#E5E5E5" />

                            <Label Text="Aucun élément"
                                   HorizontalOptions="Center"
                                   TextColor="#8A8A8A"
                                   Margin="0,20,0,20"
                                   IsVisible="{Binding IsScenesEmpty}" />

                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Ennemis -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              Padding="20,16">

                            <Label Grid.Column="0"
                                   Text="Ennemis"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />

                            <Label Grid.Column="1"
                                   Text="{Binding EnemiesCount, StringFormat='({0})'}"
                                   FontSize="14"
                                   TextColor="#7A7A7A"
                                   Margin="8,0,16,0"
                                   VerticalOptions="Center" />

                            <Button Grid.Column="2"
                                    Text="+ Ajouter"
                                    Command="{Binding AddEnemyCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Frame>
                </Grid>

                <!-- Boutiques -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              Padding="20,16">

                            <Label Grid.Column="0"
                                   Text="Boutiques"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />

                            <Label Grid.Column="1"
                                   Text="{Binding ShopsCount, StringFormat='({0})'}"
                                   FontSize="14"
                                   TextColor="#7A7A7A"
                                   Margin="8,0,16,0"
                                   VerticalOptions="Center" />

                            <Button Grid.Column="2"
                                    Text="+ Ajouter"
                                    Command="{Binding AddShopCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Frame>
                </Grid>

                <!-- Personnages -->
                <Grid ColumnDefinitions="1*,8*,1*">
                    <Frame Grid.Column="1"
                           Style="{StaticResource SectionFrameStyle}">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              Padding="20,16">

                            <Label Grid.Column="0"
                                   Text="Personnages"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />

                            <Label Grid.Column="1"
                                   Text="{Binding PlayerCharactersCount, StringFormat='({0})'}"
                                   FontSize="14"
                                   TextColor="#7A7A7A"
                                   Margin="8,0,16,0"
                                   VerticalOptions="Center" />

                            <Button Grid.Column="2"
                                    Text="+ Ajouter"
                                    Command="{Binding AddPlayerCharacterCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Frame>
                </Grid>

                <!-- Sauvegarde -->
                <Grid ColumnDefinitions="1*,8*,1*"
                      Margin="0,20,0,30">

                    <Button Grid.Column="1"
                            Text="Sauvegarder le scénario"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HeightRequest="50" />
                </Grid>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>